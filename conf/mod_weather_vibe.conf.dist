# Theme: Scorched red earth, barren crags, no vegetation. Dry year-round.
# Sandstorms and clear baking heat dominate. Rain is extremely rare.
# No snow  -  too low and hot.
#======================================================================

# Spring: warm and dry, occasional dust
WeatherVibe.Profile.Badlands.Spring.1=45,0,50,80
WeatherVibe.Profile.Badlands.Spring.2=10,1,20,40
WeatherVibe.Profile.Badlands.Spring.3=5,3,20,40
