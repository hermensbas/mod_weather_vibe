#######################################################################################################
#######################################################################################################
#  mod_weather_vibe
#
# Notes
# - Use admin commands to drive weather per zone:
#     .wvibe set <zoneId> <type:0|1|2|3|86> <percentage:0..100>
#     .wvibe setRaw <zoneId> <type:0|1|2|3|86> <raw:0..1>
#     .wvibe show  (lists last-applied entries)
#######################################################################################################
#######################################################################################################

# Toggle module
# ----------------------------------------------------------------------
WeatherVibe.Enable = 1

# Optional debug (zone-wide broadcast of pushes)
# ----------------------------------------------------------------------
WeatherVibe.Debug = 0

# Toggle weather profiles (automatic weather engine).
# When disabled, manual commands (.wvibe set / setRaw) still work
# but profiles will not drive weather automatically.
# ----------------------------------------------------------------------
WeatherVibe.Profile.Enable = 1
WeatherVibe.Profile.ReApply.PerSec = 30

#######################################################################################################
#######################################################################################################
# Dayparts & Season (core)
#######################################################################################################

# Season: auto|spring|summer|autumn|winter.
# ----------------------------------------------------------------------
WeatherVibe.Season = auto

# Mode: auto|morning|afternoon|evening|night.
# ----------------------------------------------------------------------
WeatherVibe.DayPart.Mode = auto

# DayPart times.
# ----------------------------------------------------------------------
WeatherVibe.DayPart.MORNING.Start   = 06:00
WeatherVibe.DayPart.AFTERNOON.Start = 12:00
WeatherVibe.DayPart.EVENING.Start   = 18:00
WeatherVibe.DayPart.NIGHT.Start     = 22:00


#######################################################################################################
#######################################################################################################
# Internal intensity ranges - raw grade clamps per daypart/state (core)
# Defaults: 0.30 - 0.90 for every WeatherState and every daypart.
#######################################################################################################

# Fine (0)
# ----------------------------------------------------------------------
WeatherVibe.Intensity.InternalRange.MORNING.Fine          = 0.00, 0.30
WeatherVibe.Intensity.InternalRange.AFTERNOON.Fine        = 0.00, 0.30
WeatherVibe.Intensity.InternalRange.EVENING.Fine          = 0.00, 0.30
WeatherVibe.Intensity.InternalRange.NIGHT.Fine            = 0.00, 0.30

# Fog (1)
# ----------------------------------------------------------------------
WeatherVibe.Intensity.InternalRange.MORNING.Fog           = 0.15, 0.30
WeatherVibe.Intensity.InternalRange.AFTERNOON.Fog         = 0.15, 0.30
WeatherVibe.Intensity.InternalRange.EVENING.Fog           = 0.15, 0.30
WeatherVibe.Intensity.InternalRange.NIGHT.Fog             = 0.15, 0.30

# Light Rain (3)
# ----------------------------------------------------------------------
WeatherVibe.Intensity.InternalRange.MORNING.LightRain     = 0.25, 0.50
WeatherVibe.Intensity.InternalRange.AFTERNOON.LightRain   = 0.25, 0.50
WeatherVibe.Intensity.InternalRange.EVENING.LightRain     = 0.25, 0.50
WeatherVibe.Intensity.InternalRange.NIGHT.LightRain       = 0.25, 0.50

# Medium Rain (4)
# ----------------------------------------------------------------------
WeatherVibe.Intensity.InternalRange.MORNING.MediumRain    = 0.25, 0.70
WeatherVibe.Intensity.InternalRange.AFTERNOON.MediumRain  = 0.25, 0.70
WeatherVibe.Intensity.InternalRange.EVENING.MediumRain    = 0.25, 0.70
WeatherVibe.Intensity.InternalRange.NIGHT.MediumRain      = 0.25, 0.80

# Heavy Rain (5)
# ----------------------------------------------------------------------
WeatherVibe.Intensity.InternalRange.MORNING.HeavyRain     = 0.25, 0.90
WeatherVibe.Intensity.InternalRange.AFTERNOON.HeavyRain   = 0.25, 0.90
WeatherVibe.Intensity.InternalRange.EVENING.HeavyRain     = 0.25, 0.90
WeatherVibe.Intensity.InternalRange.NIGHT.HeavyRain       = 0.25, 0.90

# Light Snow (6)
# ----------------------------------------------------------------------
WeatherVibe.Intensity.InternalRange.MORNING.LightSnow     = 0.25, 0.50
WeatherVibe.Intensity.InternalRange.AFTERNOON.LightSnow   = 0.25, 0.50
WeatherVibe.Intensity.InternalRange.EVENING.LightSnow     = 0.25, 0.50
WeatherVibe.Intensity.InternalRange.NIGHT.LightSnow       = 0.25, 0.50

# Medium Snow (7)
# ----------------------------------------------------------------------
WeatherVibe.Intensity.InternalRange.MORNING.MediumSnow    = 0.25, 0.70
WeatherVibe.Intensity.InternalRange.AFTERNOON.MediumSnow  = 0.25, 0.70
WeatherVibe.Intensity.InternalRange.EVENING.MediumSnow    = 0.25, 0.70
WeatherVibe.Intensity.InternalRange.NIGHT.MediumSnow      = 0.25, 0.70

# Heavy Snow (8)
# ----------------------------------------------------------------------
WeatherVibe.Intensity.InternalRange.MORNING.HeavySnow     = 0.25, 0.90
WeatherVibe.Intensity.InternalRange.AFTERNOON.HeavySnow   = 0.25, 0.90
WeatherVibe.Intensity.InternalRange.EVENING.HeavySnow     = 0.25, 0.90
WeatherVibe.Intensity.InternalRange.NIGHT.HeavySnow       = 0.25, 0.90

# Light Sandstorm (22)
# ----------------------------------------------------------------------
WeatherVibe.Intensity.InternalRange.MORNING.LightSandstorm   = 0.25, 0.50
WeatherVibe.Intensity.InternalRange.AFTERNOON.LightSandstorm = 0.25, 0.50
WeatherVibe.Intensity.InternalRange.EVENING.LightSandstorm   = 0.25, 0.50
WeatherVibe.Intensity.InternalRange.NIGHT.LightSandstorm     = 0.25, 0.50

# Medium Sandstorm (41)
# ----------------------------------------------------------------------
WeatherVibe.Intensity.InternalRange.MORNING.MediumSandstorm  = 0.25, 0.70
WeatherVibe.Intensity.InternalRange.AFTERNOON.MediumSandstorm= 0.25, 0.70
WeatherVibe.Intensity.InternalRange.EVENING.MediumSandstorm  = 0.25, 0.70
WeatherVibe.Intensity.InternalRange.NIGHT.MediumSandstorm    = 0.25, 0.70

# Heavy Sandstorm (42)
# ----------------------------------------------------------------------
WeatherVibe.Intensity.InternalRange.MORNING.HeavySandstorm   = 0.25, 0.90
WeatherVibe.Intensity.InternalRange.AFTERNOON.HeavySandstorm = 0.25, 0.90
WeatherVibe.Intensity.InternalRange.EVENING.HeavySandstorm   = 0.25, 0.90
WeatherVibe.Intensity.InternalRange.NIGHT.HeavySandstorm     = 0.25, 0.90

# Thunders (86)
# ----------------------------------------------------------------------
WeatherVibe.Intensity.InternalRange.MORNING.Thunders         = 0.15, 0.40
WeatherVibe.Intensity.InternalRange.AFTERNOON.Thunders       = 0.15, 0.40
WeatherVibe.Intensity.InternalRange.EVENING.Thunders         = 0.15, 0.40
WeatherVibe.Intensity.InternalRange.NIGHT.Thunders           = 0.15, 0.50


#######################################################################################################
#######################################################################################################
# WeatherVibe  -  Complete Zone Weather Profiles
# Format: weight, weatherType, intensityMinPct, intensityMaxPct
# Weather Types:
#           0=Fine, 1=Fog,
#           3=LightRain, 4=MediumRain, 5=HeavyRain,
#           6=LightSnow, 7=MediumSnow, 8=HeavySnow,
#           22=LightSandstorm, 41=MediumSandstorm, 42=HeavySandstorm,
#           86=Thunders
#######################################################################################################
#######################################################################################################


#======================================================================
# DunMorogh  -  High-altitude snowy mountain region
# Theme: Permanent snow, dwarven highlands. Snow dominant year-round.
# Clear crisp days, mountain fog, rare sleet, summer thunderstorms.
#======================================================================

# Spring: snow easing, clear days emerging, valley fog, rare sleet
WeatherVibe.Profile.DunMorogh.Spring.1=10,0,40,70
WeatherVibe.Profile.DunMorogh.Spring.2=15,1,30,60
WeatherVibe.Profile.DunMorogh.Spring.3=5,3,30,50
WeatherVibe.Profile.DunMorogh.Spring.4=40,6,30,50
WeatherVibe.Profile.DunMorogh.Spring.5=15,7,30,70
WeatherVibe.Profile.DunMorogh.Spring.6=10,8,30,80

# Summer: mildest season, most clear days, light snow persists, morning fog, rare drizzle, occasional thunderstorms
WeatherVibe.Profile.DunMorogh.Summer.1=30,0,50,80
WeatherVibe.Profile.DunMorogh.Summer.2=15,1,30,60
WeatherVibe.Profile.DunMorogh.Summer.3=8,3,30,50
WeatherVibe.Profile.DunMorogh.Summer.4=25,6,30,40
WeatherVibe.Profile.DunMorogh.Summer.5=12,7,30,60
WeatherVibe.Profile.DunMorogh.Summer.6=5,8,30,60
WeatherVibe.Profile.DunMorogh.Summer.7=5,86,30,50

# Autumn: colder, snow increasing, thick fog, fewer clear days
WeatherVibe.Profile.DunMorogh.Autumn.1=10,0,30,60
WeatherVibe.Profile.DunMorogh.Autumn.2=20,1,30,70
WeatherVibe.Profile.DunMorogh.Autumn.3=35,6,30,50
WeatherVibe.Profile.DunMorogh.Autumn.4=15,7,30,70
WeatherVibe.Profile.DunMorogh.Autumn.5=15,8,30,80

# Winter: harshest, heavy snow and blizzards dominant, rare clear cold days, dense mountain fog
WeatherVibe.Profile.DunMorogh.Winter.1=5,0,30,50
WeatherVibe.Profile.DunMorogh.Winter.2=10,1,40,70
WeatherVibe.Profile.DunMorogh.Winter.3=20,6,30,50
WeatherVibe.Profile.DunMorogh.Winter.4=30,7,30,80
WeatherVibe.Profile.DunMorogh.Winter.5=30,8,40,90

WeatherVibe.Profile.DunMorogh.Transition.Step.TimeSeconds.Min=15
WeatherVibe.Profile.DunMorogh.Transition.Step.TimeSeconds.Max=35
WeatherVibe.Profile.DunMorogh.Transition.StepSize.Perc=20
WeatherVibe.Profile.DunMorogh.Transition.Max.Changes.Per.Hour=12
WeatherVibe.Profile.DunMorogh.Transition.Max.Consecutive.Same=2
WeatherVibe.Profile.DunMorogh.Transition.MinHoldSeconds=60
WeatherVibe.Profile.DunMorogh.Transition.SeasonBlendMinutes=10


#======================================================================
